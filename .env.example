# LinkedIn Developer App credentials
# Get these from: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# Optional: set token directly instead of running auth.py
# LINKEDIN_ACCESS_TOKEN=your_access_token_here

# Comma-separated list of email addresses safe to include in posts (used by pre_post_check.py)
LINKEDIN_OWNER_EMAILS=you@example.com,alias@example.com
